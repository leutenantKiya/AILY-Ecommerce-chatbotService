<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.aily.controller.AdminProductsController"
      styleClass="root-bg"
      prefWidth="1920" prefHeight="1080">

    <!-- Sidebar -->
    <VBox styleClass="sidebar" prefWidth="260" minWidth="260">
        <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="AILY" styleClass="logo-text"/>
            <Label text="ADMIN" styleClass="admin-badge"/>
        </HBox>
        <Region styleClass="sidebar-divider" prefHeight="1"><VBox.margin><Insets top="16" bottom="16"/></VBox.margin></Region>
        <Label text="Menu Utama" styleClass="sidebar-section-label"/>
        <Button text="📊  Overview"       onAction="#goOverview"     styleClass="menu-item-btn"/>
        <Button text="📦  Kelola Produk"  onAction="#goProducts"     styleClass="menu-item-btn-active"><VBox.margin><Insets top="4"/></VBox.margin></Button>
        <Button text="🏪  Info Toko"      onAction="#goStoreInfo"    styleClass="menu-item-btn"><VBox.margin><Insets top="4"/></VBox.margin></Button>
        <Button text="💳  Transaksi"      onAction="#goTransactions"  styleClass="menu-item-btn"><VBox.margin><Insets top="4"/></VBox.margin></Button>
        <Button text="💬  Riwayat Chat"   onAction="#goChatHistory"   styleClass="menu-item-btn"><VBox.margin><Insets top="4"/></VBox.margin></Button>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="[← Keluar" onAction="#handleLogout" styleClass="logout-btn"/>
    </VBox>

    <!-- Content -->
    <ScrollPane fitToWidth="true" styleClass="chat-scroll" HBox.hgrow="ALWAYS" hbarPolicy="NEVER">
        <content>
            <VBox styleClass="admin-content" spacing="24">
                <Label text="Kelola Produk" styleClass="page-title"/>

                <!-- Form card -->
                <VBox styleClass="form-card" spacing="16">
                    <Label text="+ Tambah/Edit Produk" styleClass="form-section-title"/>
                    <Region styleClass="form-divider" prefHeight="1"/>

                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Nama Produk" styleClass="field-label"/>
                            <TextField fx:id="namaProdukField" promptText="cth: Laptop Asus" styleClass="input-dark-sm"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Kode Produk" styleClass="field-label"/>
                            <TextField fx:id="kodeProdukField" promptText="cth: LAP-001" styleClass="input-dark-sm"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Harga (Rp)" styleClass="field-label"/>
                            <TextField fx:id="hargaField" promptText="0" styleClass="input-dark-sm"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Stok" styleClass="field-label"/>
                            <TextField fx:id="stokField" promptText="0" styleClass="input-dark-sm"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="6">
                        <Label text="Deskripsi" styleClass="field-label"/>
                        <TextArea fx:id="deskripsiField" promptText="Deskripsi Produk"
                                  styleClass="textarea-dark" prefHeight="90" wrapText="true"/>
                    </VBox>
                    
                    <VBox spacing="6">
                        <Label styleClass="field-label" text="Gambar Produk" />
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="Pilih Gambar" onAction="#handleChooseImage" styleClass="btn-gray" />
                            <Label fx:id="imageNameLabel" text="Belum ada gambar" styleClass="text-gray" />
                        </HBox>
                    </VBox>

                    <Button fx:id="saveButton" text="Simpan Produk" onAction="#handleSave"
                            styleClass="btn-teal" prefWidth="180"/>
                </VBox>

                <!-- Product list table -->
                <VBox styleClass="table-card" spacing="0">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Daftar Produk" styleClass="form-section-title" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="produkCountLabel" text="0 produk" styleClass="text-gray"/>
                    </HBox>
                    <Region styleClass="form-divider" prefHeight="1"><VBox.margin><Insets top="12" bottom="8"/></VBox.margin></Region>

                    <HBox styleClass="table-header-row">
                        <Label text="ID"     styleClass="table-col-label" prefWidth="120"/>
                        <Label text="NAMA"   styleClass="table-col-label" prefWidth="200"/>
                        <Label text="HARGA"  styleClass="table-col-label" prefWidth="160"/>
                        <Label text="STOK"   styleClass="table-col-label" prefWidth="100"/>
                        <Label text="AKSI"   styleClass="table-col-label" prefWidth="120"/>
                    </HBox>

                    <VBox fx:id="productRowsBox"/>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</HBox>
