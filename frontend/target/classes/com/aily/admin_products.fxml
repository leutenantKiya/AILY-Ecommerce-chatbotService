<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="880" prefWidth="1280" styleClass="root-bg" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aily.controller.AdminProductsController">

    <!-- Sidebar -->
    <VBox minWidth="260" prefWidth="260" styleClass="sidebar">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label styleClass="logo-text" text="AILY" />
            <Label styleClass="admin-badge" text="ADMIN" />
        </HBox>
        <Region prefHeight="1" styleClass="sidebar-divider"><VBox.margin><Insets bottom="16" top="16" /></VBox.margin></Region>
        <Label styleClass="sidebar-section-label" text="Menu Utama" />
        <Button onAction="#goOverview" styleClass="menu-item-btn" text="📊  Overview" />
        <Button onAction="#goProducts" styleClass="menu-item-btn-active" text="📦  Kelola Produk"><VBox.margin><Insets top="4" /></VBox.margin></Button>
        <Button onAction="#goTransactions" styleClass="menu-item-btn" text="💳  Transaksi"><VBox.margin><Insets top="4" /></VBox.margin></Button>
        <Button onAction="#goChatHistory" styleClass="menu-item-btn" text="💬  Riwayat Chat"><VBox.margin><Insets top="4" /></VBox.margin></Button>
        <Region VBox.vgrow="ALWAYS" />
        <Button onAction="#handleLogout" styleClass="logout-btn" text="[← Keluar" />
    </VBox>

    <!-- Content -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="chat-scroll" HBox.hgrow="ALWAYS">
            <VBox spacing="24" styleClass="admin-content">
                <Label styleClass="page-title" text="Kelola Produk" />

                <!-- Form card -->
                <VBox spacing="16" styleClass="form-card">
                    <Label styleClass="form-section-title" text="+ Tambah/Edit Produk" />
                    <Region prefHeight="1" styleClass="form-divider" />

                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Nama Produk" />
                            <TextField fx:id="namaProdukField" promptText="cth: Laptop Asus" styleClass="input-dark-sm" />
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Kode Produk" />
                            <TextField fx:id="kodeProdukField" promptText="cth: LAP-001" styleClass="input-dark-sm" />
                        </VBox>
                    </HBox>
                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Harga (Rp)" />
                            <TextField fx:id="hargaField" promptText="0" styleClass="input-dark-sm" />
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="field-label" text="Stok" />
                            <TextField fx:id="stokField" promptText="0" styleClass="input-dark-sm" />
                        </VBox>
                    </HBox>
                    <VBox spacing="6">
                        <Label styleClass="field-label" text="Deskripsi" />
                        <TextArea fx:id="deskripsiField" prefHeight="90" promptText="Deskripsi Produk" styleClass="textarea-dark" wrapText="true" />
                    </VBox>

                    <Button fx:id="saveButton" onAction="#handleSave" prefWidth="180" styleClass="btn-teal" text="Simpan Produk" />
                </VBox>

                <!-- Product list table -->
                <VBox styleClass="table-card">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="form-section-title" text="Daftar Produk" HBox.hgrow="ALWAYS" />
                        <Label fx:id="produkCountLabel" styleClass="text-gray" text="0">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin></Label>
                  <Label text="produk" />
                    </HBox>
                    <Region prefHeight="1" styleClass="form-divider"><VBox.margin><Insets bottom="8" top="12" /></VBox.margin></Region>

                    <HBox styleClass="table-header-row">
                        <Label prefWidth="120" styleClass="table-col-label" text="ID" />
                        <Label prefWidth="200" styleClass="table-col-label" text="NAMA" />
                        <Label prefWidth="160" styleClass="table-col-label" text="HARGA" />
                        <Label prefWidth="100" styleClass="table-col-label" text="STOK" />
                        <Label prefWidth="120" styleClass="table-col-label" text="AKSI" />
                    </HBox>

                    <VBox fx:id="productRowsBox" />
                </VBox>
            </VBox>
    </ScrollPane>
</HBox>
